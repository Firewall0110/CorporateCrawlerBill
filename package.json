{
  "name": "corporate-crawler-bill",
  "version": "1.0.0",
  "description": "Multiplayer beat'em up game - CorporateCrawlerBill",
  "private": true,
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.6.1"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "server": "node server.js",
    "server:dev": "nodemon server.js",
    "stage:gen": "npm install --no-save @napi-rs/canvas && node scripts/generate-stage.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "yaml": "^2.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
